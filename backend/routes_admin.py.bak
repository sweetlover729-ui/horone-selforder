    params.append(service_type_id)
    query = sql.SQL('UPDATE service_types SET {} WHERE id = %s').format(
        sql.SQL(', ').join(set_clauses)
    )
    cursor.execute(query, params)
    conn.commit()
    database.release_connection(conn)
    
    return jsonify({'success': True})

