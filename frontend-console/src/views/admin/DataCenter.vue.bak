          </el-radio-group>
        </div>
        <el-input
          v-model="searchQuery"
          placeholder="搜索产品类型、品牌、型号..."
          clearable
          style="width: 200px; margin-left: 12px;"
          @input="handleSearch"
        >
          <template #prefix>
            <el-icon><Search /></el-icon>
          </template>
        </el-input>
      </div>
    </div>

    <!-- Tab 切换 -->
    <div class="tab-bar">
      <div
        v-for="tab in tabs"
        :key="tab.key"
        class="tab-item"
        :class="{ active: activeTab === tab.key }"
        @click="activeTab = tab.key"
      >
        <span class="tab-icon">{{ tab.icon }}</span>
        <span class="tab-label">{{ tab.label }}</span>
      </div>
    </div>

    <!-- 产品体系 Tab -->
    <div v-if="activeTab === 'product'">
      <!-- 品牌中心布局 -->
      <BrandCentricLayout v-if="layoutMode === 'brand'" :data="layoutData" @select-brand="handleSelectBrand" @open-dialog="handleOpenDialog" />
      <!-- 层级递进布局 -->
      <TierLayout v-else-if="layoutMode === 'tier'" :data="layoutData" @select="handleTierSelect" @open-dialog="handleOpenDialog" />
      <!-- 矩阵视图 -->
      <MatrixLayout v-else-if="layoutMode === 'matrix'" :data="layoutData" @select="handleMatrixSelect" @open-dialog="handleOpenDialog" />
    </div>
      <!-- 左侧：产品大类导航 -->
      <div class="sidebar-panel">
