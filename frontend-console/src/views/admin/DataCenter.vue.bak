        </div>
        <el-table :data="serviceTypes" size="small" stripe>
          <el-table-column prop="name" label="服务名称" min-width="150" />
          <el-table-column prop="product_type_name" label="所属产品" width="120" />
          <el-table-column prop="base_price" label="基础价格" width="100">
            <template #default="{ row }">
              <span class="price-tag">¥{{ row.base_price }}</span>
            </template>
          </el-table-column>
          <el-table-column prop="description" label="描述" min-width="200" show-overflow-tooltip />
          <el-table-column label="状态" width="80" align="center">
            <template #default="{ row }">
              <el-tag :type="row.is_active === 1 ? 'success' : 'info'" size="small">
                {{ row.is_active === 1 ? '启用' : '禁用' }}
