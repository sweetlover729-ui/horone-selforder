const serviceTypeFormRef = ref(null)

const openServiceTypeDialog = (row = null) => {
  isEditServiceType.value = !!row
  serviceTypeForm.value = row
    ? { ...row }
    : { id: '', name: '', product_type_id: selectedType.value?.id || '', base_price: 0, description: '', is_active: 1 }
  serviceTypeDialogVisible.value = true
}

const submitServiceType = async () => {
  submitLoading.value = true
  try {
