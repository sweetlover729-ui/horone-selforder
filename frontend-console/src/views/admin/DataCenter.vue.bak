          <el-button type="primary" link size="small" @click="openTypeDialog()">+ 新增</el-button>
        </div>
        <div class="type-list">
          <div
            v-for="type in productTypes"
            :key="type.id"
            class="type-item"
            :class="{ active: selectedType?.id === type.id }"
          >
            <div class="type-content" @click="selectType(type)">
              <div class="type-name">{{ type.name }}</div>
              <div class="type-meta">
                <el-tag size="small" type="info">{{ getTypeStats(type.id) }}</el-tag>
              </div>
            </div>
            <div class="type-actions">
              <el-button type="primary" link size="small" @click.stop="openTypeDialog(type)">编辑</el-button>
              <el-button type="danger" link size="small" @click.stop="deleteProductType(type)">删除</el-button>
            </div>
          </div>
        </div>
      </div>

      <!-- 中间：产品类型 + 品牌 -->
      <div class="content-panel">
        <!-- 产品类型区 -->
        <div class="section" v-if="selectedType">
          <div class="section-header">
            <h3>产品类型</h3>
            <el-button type="primary" link size="small" @click="openCategoryDialog()">+ 新增类型</el-button>
          </div>
          <div class="category-tags">
            <el-tag
              v-for="cat in typeCategories"
              :key="cat.id"
              :type="selectedCategory?.id === cat.id ? 'primary' : 'info'"
              size="large"
              class="category-tag"
              @click="selectCategory(cat)"
            >
              {{ cat.name }}
              <span class="tag-count">({{ getCategoryModelCount(cat.id) }})</span>
              <el-icon class="tag-edit" @click.stop="openCategoryDialog(cat)"><Edit /></el-icon>
            </el-tag>
            <el-tag v-if="!typeCategories.length" type="info" size="large">暂无产品类型</el-tag>
          </div>
          <!-- 产品类型操作栏 -->
          <div v-if="selectedCategory" class="category-actions">
            <el-button type="primary" link size="small" @click="openCategoryDialog(selectedCategory)">编辑</el-button>
            <el-button type="danger" link size="small" @click="deleteCategory(selectedCategory)">删除</el-button>
          </div>
        </div>

        <!-- 品牌区 -->
        <div class="section" v-if="selectedType">
          <div class="section-header">
            <h3>品牌</h3>
            <el-button type="primary" link size="small" @click="openBrandDialog()">+ 新增品牌</el-button>
          </div>
          <div class="brand-grid">
            <div
              v-for="brand in typeBrands"
              :key="brand.id"
              class="brand-card"
              :class="{ active: selectedBrand?.id === brand.id }"
            >
              <div class="brand-content" @click="selectBrand(brand)">
                <div class="brand-name">{{ brand.name }}</div>
                <div class="brand-count">{{ getBrandModelCount(brand.id) }} 个型号</div>
              </div>
              <div class="brand-actions">
                <el-button type="primary" link size="small" @click.stop="openBrandDialog(brand)">编辑</el-button>
                <el-button type="danger" link size="small" @click.stop="deleteBrand(brand)">删除</el-button>
              </div>
            </div>
            <el-empty v-if="!typeBrands.length" description="暂无品牌" :image-size="60" />
          </div>
        </div>

        <!-- 型号详情区 -->
        <div class="section" v-if="selectedBrand">
          <div class="section-header">
            <h3>型号列表</h3>
            <el-button type="primary" link size="small" @click="openModelDialog()">+ 新增型号</el-button>
          </div>
          <el-table :data="brandModels" size="small" stripe>
            <el-table-column prop="name" label="型号名称" min-width="150" />
            <el-table-column label="产品类型" width="200">
              <template #default="{ row }">
                <div class="model-categories">
                  <el-tag v-for="cat in row.categories" :key="cat" size="small" type="info">
                    {{ cat }}
                  </el-tag>
                </div>
              </template>
            </el-table-column>
            <el-table-column label="状态" width="80" align="center">
              <template #default="{ row }">
                <el-tag :type="row.is_active === 1 ? 'success' : 'info'" size="small">
                  {{ row.is_active === 1 ? '启用' : '禁用' }}
                </el-tag>
              </template>
            </el-table-column>
            <el-table-column label="操作" width="120" align="center">
              <template #default="{ row }">
                <el-button type="primary" link size="small" @click="openModelDialog(row)">编辑</el-button>
                <el-button type="danger" link size="small" @click="deleteModel(row)">删除</el-button>
              </template>
            </el-table-column>
          </el-table>
        </div>
      </div>

      <!-- 右侧：服务与价格 -->
      <div class="right-panel">
        <!-- 服务类型 -->
        <div class="section">
          <div class="section-header">
            <h3>服务类型</h3>
            <el-button type="primary" link size="small" @click="openServiceTypeDialog()">+ 新增</el-button>
          </div>
          <div class="service-list">
