            </div>
            <el-empty v-if="!filteredServiceTypes.length" description="暂无服务类型" :image-size="60" />
          </div>
        </div>

        <!-- 检项 -->
        <div class="section">
          <div class="section-header">
            <h3>维修检项</h3>
            <el-button type="primary" link size="small" @click="openServiceItemDialog()">+ 新增</el-button>
          </div>
          <div class="item-list">
            <div v-for="item in filteredServiceItems" :key="item.id" class="item-row">
              <el-tag :type="item.is_required === 1 ? 'danger' : 'default'" size="small">
                {{ item.is_required === 1 ? '必检' : '可检' }}
              </el-tag>
              <span class="item-name">{{ item.name }}</span>
            </div>
            <el-empty v-if="!filteredServiceItems.length" description="暂无检项" :image-size="60" />
          </div>
        </div>

        <!-- 价格配置 -->
        <div class="section">
          <div class="section-header">
            <h3>价格配置</h3>
            <el-button type="primary" link size="small" @click="openPriceDialog()">+ 新增</el-button>
          </div>
          <div class="price-list">
            <div v-for="price in filteredPrices" :key="price.id" class="price-item">
              <div class="price-info">
                <span>{{ price.service_type_name }}</span>
