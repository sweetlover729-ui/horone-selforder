            <template #default="{ row }">
              <el-button type="primary" link size="small" @click="openServiceTypeDialog(row)">编辑</el-button>
              <el-button type="danger" link size="small" @click="deleteServiceType(row)">删除</el-button>
            </template>
          </el-table-column>
        </el-table>
      </div>

      <div class="section" style="margin-top: 20px;">
        <div class="section-header">
          <h3>维修检项管理</h3>
          <el-button type="primary" @click="openServiceItemDialog()">+ 新增检项</el-button>
        </div>
        <el-table :data="serviceItems" size="small" stripe>
          <el-table-column prop="name" label="检项名称" min-width="200" />
          <el-table-column prop="product_type_name" label="所属产品" width="120" />
          <el-table-column label="类型" width="80" align="center">
            <template #default="{ row }">
              <el-tag :type="row.is_required === 1 ? 'danger' : 'warning'" size="small">
                {{ row.is_required === 1 ? '必检' : '可检' }}
              </el-tag>
            </template>
          </el-table-column>
          <el-table-column label="操作" width="150" align="center" fixed="right">
            <template #default="{ row }">
              <el-button type="primary" link size="small" @click="openServiceItemDialog(row)">编辑</el-button>
              <el-button type="danger" link size="small" @click="deleteServiceItem(row)">删除</el-button>
            </template>
          </el-table-column>
        </el-table>
      </div>
    </div>

    <!-- 价格体系 Tab -->
    <div v-if="activeTab === 'price'" class="full-panel">
      <div class="section">
        <div class="section-header">
          <h3>价格配置管理</h3>
          <el-button type="primary" @click="openPriceDialog()">+ 新增价格</el-button>
        </div>
        <el-table :data="prices" size="small" stripe>
          <el-table-column prop="service_type_name" label="服务类型" min-width="150" />
          <el-table-column prop="product_type_name" label="产品大类" width="120" />
          <el-table-column prop="category" label="产品类型" width="120" />
          <el-table-column prop="brand_name" label="品牌" width="120" />
          <el-table-column prop="model_name" label="型号" width="150" />
          <el-table-column prop="price" label="价格" width="100">
            <template #default="{ row }">
              <span class="price-tag">¥{{ row.price }}</span>
            </template>
          </el-table-column>
          <el-table-column label="操作" width="150" align="center" fixed="right">
            <template #default="{ row }">
              <el-button type="primary" link size="small" @click="openPriceDialog(row)">编辑</el-button>
              <el-button type="danger" link size="small" @click="deletePrice(row)">删除</el-button>
            </template>
          </el-table-column>
        </el-table>
      </div>
    </div>

    <!-- 弹窗们 -->
    <!-- 产品大类弹窗 -->
    <el-dialog v-model="typeDialogVisible" :title="isEditType ? '编辑产品大类' : '新增产品大类'" width="500px">
      <el-form :model="typeForm" ref="typeFormRef" label-width="100px">
        <el-form-item label="名称" required>
          <el-input v-model="typeForm.name" placeholder="如：调节器" />
        </el-form-item>
        <el-form-item label="套装分类">
          <el-select
            v-model="typeForm.categories"
            placeholder="选择关联的产品类型"
            multiple
            clearable
            style="width: 100%"
          >
            <el-option
              v-for="opt in categoryOptions"
              :key="opt.value"
              :label="opt.label"
              :value="opt.value"
            />
          </el-select>
        </el-form-item>
        <el-form-item label="排序">
          <el-input-number v-model="typeForm.sort_order" :min="0" />
        </el-form-item>
      </el-form>
      <template #footer>
        <el-button @click="typeDialogVisible = false">取消</el-button>
        <el-button type="primary" @click="submitType" :loading="submitLoading">确定</el-button>
      </template>
    </el-dialog>

    <!-- 产品类型弹窗 -->
    <el-dialog v-model="categoryDialogVisible" :title="isEditCategory ? '编辑产品类型' : '新增产品类型'" width="500px">
      <el-form :model="categoryForm" ref="categoryFormRef" label-width="100px">
        <el-form-item label="名称" required>
          <el-input v-model="categoryForm.name" placeholder="如：一级头" />
        </el-form-item>
        <el-form-item label="归属产品大类" required>
          <el-select v-model="categoryForm.product_type_id" placeholder="选择所属产品大类" style="width: 100%">
            <el-option v-for="type in productTypes" :key="type.id" :label="type.name" :value="type.id" />
          </el-select>
        </el-form-item>
        <el-form-item label="描述">
          <el-input v-model="categoryForm.description" type="textarea" :rows="2" />
        </el-form-item>
        <el-form-item label="排序">
          <el-input-number v-model="categoryForm.sort_order" :min="0" />
        </el-form-item>
      </el-form>
      <template #footer>
        <el-button @click="categoryDialogVisible = false">取消</el-button>
        <el-button type="primary" @click="submitCategory" :loading="submitLoading">确定</el-button>
      </template>
    </el-dialog>

    <!-- 品牌弹窗 -->
    <el-dialog v-model="brandDialogVisible" :title="isEditBrand ? '编辑品牌' : '新增品牌'" width="500px">
      <el-form :model="brandForm" ref="brandFormRef" label-width="100px">
        <el-form-item label="品牌名称" required>
          <el-input v-model="brandForm.name" placeholder="如：Scubapro" />
        </el-form-item>
        <el-form-item label="排序">
          <el-input-number v-model="brandForm.sort_order" :min="0" />
        </el-form-item>
      </el-form>
      <template #footer>
        <el-button @click="brandDialogVisible = false">取消</el-button>
        <el-button type="primary" @click="submitBrand" :loading="submitLoading">确定</el-button>
      </template>
    </el-dialog>

    <!-- 型号弹窗 -->
    <el-dialog v-model="modelDialogVisible" :title="isEditModel ? '编辑型号' : '新增型号'" width="500px">
      <el-form :model="modelForm" ref="modelFormRef" label-width="100px">
        <el-form-item label="型号名称" required>
          <el-input v-model="modelForm.name" placeholder="如：MK25 EVO" />
        </el-form-item>
        <el-form-item label="产品类型" required>
          <el-checkbox-group v-model="modelForm.category_ids">
            <el-checkbox v-for="cat in allCategories" :key="cat.id" :label="cat.id">
              {{ cat.name }}
            </el-checkbox>
          </el-checkbox-group>
        </el-form-item>
      </el-form>
      <template #footer>
        <el-button @click="modelDialogVisible = false">取消</el-button>
        <el-button type="primary" @click="submitModel" :loading="submitLoading">确定</el-button>
      </template>
    </el-dialog>

    <!-- 服务类型弹窗 -->
    <el-dialog v-model="serviceTypeDialogVisible" :title="isEditServiceType ? '编辑服务类型' : '新增服务类型'" width="500px">
      <el-form :model="serviceTypeForm" ref="serviceTypeFormRef" label-width="100px">
        <el-form-item label="服务名称" required>
          <el-input v-model="serviceTypeForm.name" placeholder="如：标准套装保养" />
        </el-form-item>
        <el-form-item label="所属产品" required>
          <el-select v-model="serviceTypeForm.product_type_id" placeholder="选择产品大类" style="width: 100%">
            <el-option v-for="type in productTypes" :key="type.id" :label="type.name" :value="type.id" />
          </el-select>
        </el-form-item>
        <el-form-item label="基础价格" required>
          <el-input-number v-model="serviceTypeForm.base_price" :min="0" :precision="2" style="width: 100%" />
        </el-form-item>
        <el-form-item label="描述">
          <el-input v-model="serviceTypeForm.description" type="textarea" :rows="2" />
        </el-form-item>
      </el-form>
      <template #footer>
        <el-button @click="serviceTypeDialogVisible = false">取消</el-button>
        <el-button type="primary" @click="submitServiceType" :loading="submitLoading">确定</el-button>
      </template>
    </el-dialog>

    <!-- 检项弹窗 -->
    <el-dialog v-model="serviceItemDialogVisible" :title="isEditServiceItem ? '编辑检项' : '新增检项'" width="500px">
      <el-form :model="serviceItemForm" ref="serviceItemFormRef" label-width="100px">
        <el-form-item label="检项名称" required>
          <el-input v-model="serviceItemForm.name" placeholder="如：检查O型圈" />
        </el-form-item>
        <el-form-item label="所属产品" required>
          <el-select v-model="serviceItemForm.product_type_id" placeholder="选择产品大类" style="width: 100%">
            <el-option v-for="type in productTypes" :key="type.id" :label="type.name" :value="type.id" />
          </el-select>
        </el-form-item>
        <el-form-item label="是否必检">
          <el-switch v-model="serviceItemForm.is_required" :active-value="1" :inactive-value="0" />
        </el-form-item>
      </el-form>
      <template #footer>
        <el-button @click="serviceItemDialogVisible = false">取消</el-button>
        <el-button type="primary" @click="submitServiceItem" :loading="submitLoading">确定</el-button>
      </template>
    </el-dialog>

    <!-- 价格弹窗 -->
    <el-dialog v-model="priceDialogVisible" :title="isEditPrice ? '编辑价格' : '新增价格'" width="500px">
      <el-form :model="priceForm" ref="priceFormRef" label-width="100px">
        <el-form-item label="服务类型" required>
          <el-select v-model="priceForm.service_type_id" placeholder="选择服务类型" style="width: 100%">
            <el-option v-for="service in serviceTypes" :key="service.id" :label="service.name" :value="service.id" />
          </el-select>
        </el-form-item>
        <el-form-item label="产品大类" required>
          <el-select v-model="priceForm.product_type_id" placeholder="选择产品大类" style="width: 100%" @change="onPriceTypeChange">
            <el-option v-for="type in productTypes" :key="type.id" :label="type.name" :value="type.id" />
          </el-select>
        </el-form-item>
        <el-form-item label="产品类型">
          <el-select v-model="priceForm.category_id" placeholder="选择产品类型（可选）" clearable style="width: 100%">
            <el-option v-for="cat in priceCategories" :key="cat.id" :label="cat.name" :value="cat.id" />
          </el-select>
        </el-form-item>
        <el-form-item label="品牌">
          <el-select v-model="priceForm.brand_id" placeholder="选择品牌（可选）" clearable style="width: 100%">
            <el-option v-for="brand in priceBrands" :key="brand.id" :label="brand.name" :value="brand.id" />
          </el-select>
        </el-form-item>
        <el-form-item label="型号">
          <el-select v-model="priceForm.model_id" placeholder="选择型号（可选）" clearable style="width: 100%">
            <el-option v-for="model in priceModels" :key="model.id" :label="model.name" :value="model.id" />
          </el-select>
        </el-form-item>
        <el-form-item label="价格" required>
          <el-input-number v-model="priceForm.price" :min="0" :precision="2" style="width: 100%" />
        </el-form-item>
